// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  BASIC
  PREMIUM
  ADMIN
}

model Post {
  id          Int      @id @default(autoincrement())
  title       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  slug        String   @unique
  excerpt     String
  readingTime Int
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lesson {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  module      String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
